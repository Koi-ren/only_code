library(TTR)
data(iris)
idx <- sample(1:nrow(iris),40)
irisSample<-iris[idx,]
group
data(iris)
idx<-sample(1:nrow(iris),40)
irisSample<-iris[idx,]
irisSample$Species<-NULL
str(irisSample)
hc<-hclust(dist(irisSample), method="average")
plot(hc, hang=-1, labels=iris$Species[idx])
rect.hclust(hc, h=3)
#각데이터가 속한 클러스터 확인
group <-cutree(hc, k=3)
group
data(USArrests)
idx<-sample(1:nrow(iris),40)
USArSample<-iris[idx,]
View(USArSample)
idx<-sample(1:nrow(USArrests),40)
USArSample<-iris[idx,]
View(USArSample)
USArSample<-USArrests[idx,]
USArSample$Rape<-NULL
str(USArSample)
data(USArrests)
idx<-sample(1:nrow(USArrests),40)
USArSample<-USArrests[idx,]
USArSample$Rape<-NULL
str(USArSample)
hc<-hclust(dist(USArSample), method="average")
plot(hc, hang=-1, labels=USArrests$Rape[idx])
hc<-hclust(dist(USArSample), method="average")
plot(hc, hang=-1, labels=USArrests$Rape[idx])
rect.hclust(hc, h=3)
#각데이터가 속한 클러스터 확인
group <-cutree(hc, k=3)
group
summary(USArrests)
data("USArrests")
str(USArrests)
head(USArrests)
data("USArrests")
str(USArrests)
head(USArrests)
colnames(USArrests)
rownames(USArrests)
d<-dist(USArrests,method="euclidean")
d<-dist(USArrests,method="euclidean")
fit<-hclust(d,method="ave") #평균연결법
fit
par(mfrow=c(1,2))
plot(fit,cex=0.6)
plot(fit,hang=-1,cex=0.6) #hang은 레이블이 나머지 플롯 아래에 있어야하는 플롯 높이의 비율 (음수 지정시 레이블이 0에서 중단 )
par(mfrow=c(1,1))
groups<-cutree(fit,k=6)
treeheights=cutree(fit,h=30)
plot(fit)
rect.hclust(fit,k=6,border="red")
hca<-hclust(dist(USArrests))
plot(hca)
rect.hclust(hca, k = 3, border = "red")
rect.hclust(hca, h=30, which = c(2,7), border=3:4
rect.hclust(hca, h=30, which = c(2,7), border=3:4)
rect.hclust(hca, h=30, which = c(2,7), border=3:4)
rect.hclust(hca, h=30, which = c(2,7), border=3:4)
hcd <- as.dendrogram(fit)
plot(hcd, type = "rectangle", ylab = "Height") # Default plot
plot(hcd, type = "triangle", ylab = "Height") # Triangle plot
nodePar <- list(lab.cex = 0.6, pch = c(NA,19), cex = 0.7, col = "blue") # Define nodePar
plot(hcd, ylab = "Height", nodePar = nodePar, leaflab = "none") # Customized plot; remove labels
plot(hcd, xlab = "Height", nodePar = nodePar, horiz = TRUE) # Horizontal plot
edgePar = list(col = 2:3, lwd = c(10,3))
plot(hcd, ylab = "Height", nodePar = nodePar, edgePar = edgePar)
library(cluster)
agn1<-agnes(USArrests,metric="manhattan",stand=TRUE) #metric으로 거리계산법 지정(맨하튼)
agn1
par(mfrow=c(1,2))
plot(agn1)
agn2 <- agnes(daisy(USArrests), diss=TRUE, method = "complete") #daisy() 함수는 데이터 관측치 사이의 거리를 계산해 주며, 자료의 형태가 수치형일 필요가 없다는 점에서 dist() 함수보다 유연하다.
plot(agn2)
agn3 <- agnes(USArrests, method="flexible", par.meth = 0.3)
plot(agn3)
data("USArrests")
str(USArrests)
head(USArrests)
colnames(USArrests)
rownames(USArrests)
d<-dist(USArrests,method="euclidean")
fit<-hclust(d,method="ave") #평균연결법
fit
par(mfrow=c(1,2))
plot(fit,cex=0.6)
